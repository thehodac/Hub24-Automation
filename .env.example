# Copy to .env and fill in. Loaded by your shell / CI, not committed.
# This file is a TEMPLATE — keep values EMPTY, put real secrets in .env only.
BASE_URL=https://playwright.dev

# Chromatic visual regression. Get this from your Chromatic project settings.
CHROMATIC_PROJECT_TOKEN=

# Add app credentials here as needed:
# TEST_USER=
# TEST_PASSWORD=

# API testing (Playwright request) — point at the HUB24 API
API_URL=
# API_TOKEN=

# BrowserStack (cloud real-browser testing) — run: npm run test:browserstack
# Get these from browserstack.com -> Account -> Settings. NEVER commit real keys.
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# Auto-create Jira bug tickets from failed tests (Bug Report reporter).
# Set JIRA_CREATE_TICKETS=true to enable. NEVER commit the real token.
JIRA_CREATE_TICKETS=false
JIRA_BASE_URL=https://classltd.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NIT
# Epic that holds all bug tickets (from Paulo):
JIRA_EPIC_KEY=NIT-5006
JIRA_ISSUE_TYPE=Bug

# Auto-create Asana bug tasks from failed tests (runs in parallel with Jira).
# Set ASANA_CREATE_TICKETS=true to enable. NEVER commit the real token.
#   ASANA_TOKEN        Personal Access Token (app.asana.com -> Settings -> Apps -> Manage developer apps)
#   ASANA_PROJECT_GID  target project GID (open the project in Asana; GID is in the URL)
#   ASANA_SECTION_GID  optional section within that project
ASANA_CREATE_TICKETS=false
ASANA_TOKEN=
ASANA_PROJECT_GID=
ASANA_SECTION_GID=

# --- Azure DevOps (optional, runs in parallel with Jira/Asana) ---
#   AZURE_DEVOPS_ORG       organization (dev.azure.com/<org>)
#   AZURE_DEVOPS_PROJECT   project name
#   AZURE_DEVOPS_PAT       Personal Access Token (Work Items: Read & Write). NEVER commit.
#   AZURE_DEVOPS_AREA_PATH (optional) area path · AZURE_DEVOPS_PASS_STATE (optional) default "Closed"
AZURE_DEVOPS_CREATE_TICKETS=false
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_AREA_PATH=

# --- Basecamp 3 (optional, runs in parallel) ---
#   BASECAMP_TOKEN        OAuth2 access token. NEVER commit.
#   BASECAMP_ACCOUNT_ID   account id (3.basecampapi.com/<id>)
#   BASECAMP_PROJECT_ID   project/bucket id · BASECAMP_TODOLIST_ID  to-do list id
BASECAMP_CREATE_TICKETS=false
BASECAMP_TOKEN=
BASECAMP_ACCOUNT_ID=
BASECAMP_PROJECT_ID=
BASECAMP_TODOLIST_ID=
