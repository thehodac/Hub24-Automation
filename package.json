{
  "name": "hub24-automation",
  "version": "1.0.0",
  "description": "E2E test automation with Playwright + TypeScript",
  "type": "module",
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:a11y": "playwright test accessibility",
    "test:visual": "playwright test --project=visual",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "chromatic": "chromatic --playwright",
    "chromatic:report": "node scripts/chromatic-build-url.mjs",
    "chromatic:ticket": "node scripts/chromatic-to-ticket.mjs",
    "test:visual:chromatic": "node scripts/visual-with-chromatic.mjs",
    "bddgen": "bddgen",
    "bdd": "bddgen && playwright test --project=bdd",
    "test:e2e": "playwright test --project=e2e",
    "test:api": "playwright test --project=api",
    "test:saucedemo": "playwright test --project=e2e saucedemo",
    "test:saucedemo:demo": "playwright test -c playwright.demo.config.ts --project=e2e saucedemo",
    "test:browserstack": "browserstack-node-sdk playwright test --config=playwright.bs.config.ts",
    "jira:ticket": "node scripts/create-jira-ticket.mjs",
    "test:all": "playwright test --project=chromium --project=e2e --project=api --project=visual",
    "qc:report": "node scripts/qc-report.mjs"
  },
  "keywords": [
    "playwright",
    "e2e",
    "automation",
    "typescript",
    "chromatic",
    "visual-regression",
    "cucumber",
    "bdd"
  ],
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/playwright": "^0.12.8",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "axe-core": "^4.12.1",
    "browserstack-node-sdk": "^1.59.0",
    "chromatic": "^17.4.1",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "playwright-bdd": "^9.1.0",
    "typescript": "^6.0.3"
  }
}
